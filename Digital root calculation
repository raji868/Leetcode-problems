import java.util.*;
public class Main {
    public static void main(String[] args){
        Scanner s=new Scanner(System.in);
        int n=s.nextInt();
        int d;
        while(n>=10){
            int sum=0;
            while(n>0){
            d=n%10;
            sum=sum+d;
            n=n/10;
            }
            n=sum;
        }
        System.out.println(n);
        s.close();
    }
}
