class Solution:
    def reverse(self, x: int) -> int:
        # Convert to string, reverse it, then convert back to int
        # abs(x) handles the sign separately
        res = int(str(abs(x))[::-1])
        
        # Restore the sign
        if x < 0:
            res *= -1
            
        # 32-bit signed integer range check
        # -2^31 is -2147483648, 2^31 - 1 is 2147483647
        if res < -2147483648 or res > 2147483647:
            return 0
            
        return res
