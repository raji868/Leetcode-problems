class Solution:
    def findMedianSortedArrays(self, nums1: list[int], nums2: list[int]) -> float:
        # We always binary search on the smaller array to stay O(log(min(m,n)))
        A, B = nums1, nums2
        if len(A) > len(B):
            A, B = B, A
            
        total = len(A) + len(B)
        half = (total + 1) // 2
        
        left, right = 0, len(A)
        
        while left <= right:
            i = (left + right) // 2  # Partition for A
            j = half - i              # Partition for B
            
            # Use infinity for out-of-bounds to simplify comparisons
            Aleft = A[i-1] if i > 0 else float("-infinity")
            Aright = A[i] if i < len(A) else float("infinity")
            Bleft = B[j-1] if j > 0 else float("-infinity")
            Bright = B[j] if j < len(B) else float("infinity")
            
            # Correct partition found
            if Aleft <= Bright and Bleft <= Aright:
                # Odd total
                if total % 2:
                    return float(max(Aleft, Bleft))
                # Even total
                return (max(Aleft, Bleft) + min(Aright, Bright)) / 2.0
            
            elif Aleft > Bright:
                right = i - 1
            else:
                left = i + 1
