#include <iostream>
#include<vector>
using namespace std;
void merge(vector<int> &arr){
    int n=arr.size();
    int j=0;
    while(j<n-1&&arr[j]<=arr[j+1]){
        j++;
    }
    j++;
    int i=0;
    while(i<j&&j<n){
        if (arr[i]<=arr[j]){
            i++;
        }
        else{
            int val=arr[j];
            int idx=j;
            while(idx>i){
                arr[idx]=arr[idx-1];
                idx--;
            }
            arr[i]=val;
            i++;
            j++;
        }
    }
    
}
int main(){
    vector<int> arr={2,3,8,-1,7,9,10};
    merge(arr);
    for(int y:arr){
        cout<<y<<" ";
    }
    return 0;
}
