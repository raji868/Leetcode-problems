public class NextPrimeFinder{
    public static boolean isPrime(long n){
        if(n<=1) return  false;
        if(n<=3) return true;
        if (n%2==0||n%3==0) return false;
        for(long i=5;i*i<=n;i+=6){
            if(n%i==0||n%(i+2)==0){
                return false;
            }                                                                                                                                                                                                                                                                                                                                            ))
        }
        return true;
    }
    public static long findnextprime(long x){
        long candidate=x+1;
        while(true){
            if(isPrime(candidate)){
                return candidate;
            }
            candidate++;
        }
    }
}
    public static void main(String[] args){
        long x=13;
        System.out.println(findnextprime(x));
    }
    
