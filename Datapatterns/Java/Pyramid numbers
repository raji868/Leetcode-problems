import java.util.*;
public class Main
{
	public static void main(String[] args) {
		Scanner s=new Scanner(System.in);
		int n=s.nextInt();
		
		for(int i=1;i<=n;i++){
		    for(int p=0;p<=n-i-1;p++){
		        System.out.print(" ");
		    }
		    for(int j=1;j<=i;j++){
		        System.out.print(j);
		    }
		    for(int j=i-1;j>=1;j--){
		        System.out.print(j);
		    }
		    System.out.println();
		    }
	}
}
