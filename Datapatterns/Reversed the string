import java.util.*;
public class Main
{
	public static void main(String[] args) {
	    String s="Have a nice day";
	    String words[]=s.split(" ");
	    StringBuilder rev=new StringBuilder();
	    for(int i=words.length-1;i>=0;i--){
	        rev.append(words[i]);
	        if(i>0){
	            rev.append(" ");
	        }
	    }
	    System.out.println(rev.toString());
	}
}
